#include <stdio.h>

// First Fit Algorithm
void firstfit(int itemsize[], int n, int capacity) {
    int bin[n];
    int bincount = 0; // number of bins used

    for (int i = 0; i < n; i++)
        bin[i] = capacity;

    for (int i = 0; i < n; i++) {
        int placed = 0;

        for (int j = 0; j < bincount; j++) {
            if (bin[j] >= itemsize[i]) {
                bin[j] -= itemsize[i];
                printf("Item %d placed in bin %d\n", itemsize[i], j + 1);
                placed = 1;
                break;
            }
        }

        if (!placed) {
            bin[bincount] = capacity - itemsize[i];
            printf("Item %d placed in bin %d\n", itemsize[i], bincount + 1);
            bincount++;
        }
    }

    printf("Total bins used = %d\n", bincount);
}

// Best Fit Algorithm
void bestfit(int itemsize[], int n, int capacity) {
    int bin[n];
    int bincount = 0;

    for (int i = 0; i < n; i++)
        bin[i] = capacity;

    for (int i = 0; i < n; i++) {
        int bestindex = -1;
        int minspace = capacity + 1;

        for (int j = 0; j < bincount; j++) {
            if (bin[j] >= itemsize[i] && (bin[j] - itemsize[i]) < minspace) {
                bestindex = j;
                minspace = bin[j] - itemsize[i];
            }
        }

        if (bestindex != -1) {
            bin[bestindex] -= itemsize[i];
            printf("Item %d placed in bin %d\n", itemsize[i], bestindex + 1);
        } else {
            bin[bincount] = capacity - itemsize[i];
            printf("Item %d placed in bin %d\n", itemsize[i], bincount + 1);
            bincount++;
        }
    }

    printf("Total bins used = %d\n", bincount);
}

int main() {
    int n, capacity;

    printf("Enter number of items: ");
    scanf("%d", &n);

    printf("Enter bin capacity: ");
    scanf("%d", &capacity);

    int itemsize[n];

    for (int i = 0; i < n; i++) {
        printf("Enter size of item %d: ", i + 1);
        scanf("%d", &itemsize[i]);
    }

    printf("\n--- First Fit ---\n");
    firstfit(itemsize, n, capacity);

    printf("\n--- Best Fit ---\n");
    bestfit(itemsize, n, capacity);

    return 0;
}
