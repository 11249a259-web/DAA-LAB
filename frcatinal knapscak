#include<stdio.h>
struct item{
int weight;
int profit;
float ppw;
}
void sort(struct item items[n],int n){
for(int i=0;i<n,i++){
for(int j=0;j<n-1-i,j++){
if(items[j].ppw<items[j+1].ppw){
temp=items[j];
items[j]=items[j+1];
items[j+1]=temp
}
}
}
}
int main(){
int n;
int capacity;
float totalprofit==0.0;
printf("enter no of items:");
scanf("%d\n",&n);

struct item items[n];
printf("enter the wwights and profits for %d items\n",n);
for (int i=0;i<n;i++){
scanf("%d%d",&items[i].weight,&items[i].profit);
items[i].ppw=items[i].profit/items[i].weight;
}

printf("enter the capcity :");
scanf("%d\n",&capacity);

for(int i=0;i<n;i++){
if(items[i].weight<=capacity){
totalprofit+=items[i].profit;
capacity-=items[i].weight[i];
}
else{
totalprofit+=items[i].ppw*capacity;
break;
}
}
printf("max profit=% .2f\n",totalprofit);
return 0;}




